    Title = "Proximity全图互动",
    Description = "触发所有 Proximity Prompts",
    Callback = triggerAllProximity
})

Tabs.Main:AddButton({
    Title = "Click全图互动",
    Description = "触发所有 Click Detectors",
    Callback = triggerAllClick
})

Tabs.Main:AddButton({
    Title = "Touch全图互动",
    Description = "触发所有 Touch Interests",
    Callback = triggerAllTouch
})
